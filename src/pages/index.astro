<script>
  function getTarget(trigger: Element) {
    const targetId = trigger.getAttribute("data-reveal");
    return targetId
      ? document.getElementById(targetId)
      : trigger.closest("p")?.querySelector(".bio-reveal") as HTMLElement | null;
  }

  function reveal(target: HTMLElement) {
    if (target.classList.contains("invisible")) {
      target.style.maxHeight = target.scrollHeight + "px";
      target.style.opacity = "1";
      target.style.pointerEvents = "auto";
      target.classList.remove("invisible");
      setTimeout(() => target.style.maxHeight = "none", 500);
    } else {
      target.classList.remove("blurred");
    }
  }

  document.querySelectorAll(".bio-reveal-trigger").forEach((trigger) => {
    const target = getTarget(trigger);

    trigger.addEventListener("click", () => { if (target) reveal(target); });

    if (target?.classList.contains("blurred")) {
      target.addEventListener("click", () => { reveal(target); });

      target.addEventListener("mouseenter", () => trigger.classList.add("active"));
      target.addEventListener("mouseleave", () => trigger.classList.remove("active"));
    }
  });
</script>

